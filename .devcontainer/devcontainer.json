{
  "name": "Plant Care System",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  // Install Claude Code globally, restore auth credentials, then install Cloudflare Worker deps
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && mkdir -p ~/.claude && echo \"$CLAUDE_CREDENTIALS\" | base64 -d > ~/.claude/.credentials.json && cd cloudflare && npm install",

  // Auto-commit and push every 15 minutes while the Codespace is awake
  "postStartCommand": "nohup bash /workspaces/plant-care-system/scripts/auto-push.sh &>/tmp/auto-push.log &",

  "customizations": {
    "vscode": {
      "extensions": [
        // TypeScript + Workers
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        // Cloudflare Workers syntax / bindings
        "cloudflare.cloudflare-workers-bindings"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  },

  // wrangler dev runs on 8787
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "Wrangler Dev",
      "onAutoForward": "notify"
    }
  },

  // Inject Cloudflare API token from a Codespace secret named CLOUDFLARE_API_TOKEN
  // Set it at: github.com/Settings → Codespaces → Secrets
  "secrets": {
    "CLOUDFLARE_API_TOKEN": {
      "description": "Cloudflare API token — used by wrangler deploy without needing wrangler login",
      "documentationUrl": "https://developers.cloudflare.com/workers/wrangler/ci-cd/#api-token"
    },
    "CLAUDE_CREDENTIALS": {
      "description": "Base64-encoded ~/.claude/.credentials.json — run: cat ~/.claude/.credentials.json | base64 -w 0"
    }
  }
}
